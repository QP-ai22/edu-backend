            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Jane Doe\",\n  \"username\": \"janedoe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"gender\": \"female\"\n}"
